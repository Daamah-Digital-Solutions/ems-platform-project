# انسخ الملف ده لـ .env للتطوير المحلي. في الإنتاج (Render) تتحط كـ Environment Variables.

# قاعدة البيانات — محلياً SQLite، في الإنتاج رابط Postgres (Neon)
DATABASE_URL=sqlite:///./move.db
# مثال إنتاج: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# مفتاح توقيع الـ JWT — لازم قيمة عشوائية طويلة في الإنتاج
SECRET_KEY=change-me-in-production-use-a-very-long-random-string-here-please
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# روابط الواجهة المسموح لها (CORS) — مفصولة بفواصل
CORS_ORIGINS=http://localhost:5188,http://localhost:5173,http://localhost:3000

ENV=development
ZATCA_SANDBOX=true

# مفتاح الموقع العام لاستقبال الحجوزات (يتحط في موقع التسويق كـ X-API-Key)
PUBLIC_API_KEY=dev-public-key-change-me
PUBLIC_STUDIO_ID=1
