# Copy to .env for local development. In production, set these as environment variables.

# Database — SQLite locally, Postgres (e.g. Neon) in production
DATABASE_URL=sqlite:///./move.db
# Production example: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# JWT signing key — use a long random string in production
SECRET_KEY=change-me-in-production-use-a-very-long-random-string-here-please
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Allowed frontend origins (CORS), comma-separated
CORS_ORIGINS=http://localhost:5188,http://localhost:5173,http://localhost:3000

ENV=development
ZATCA_SANDBOX=true

# Public website intake key (used by the marketing site as the X-API-Key header)
PUBLIC_API_KEY=dev-public-key-change-me
PUBLIC_STUDIO_ID=1
