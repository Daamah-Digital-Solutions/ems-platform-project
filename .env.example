# Docker Compose / VPS deployment — copy to .env on the server and fill in.

# Domain Caddy serves (real domain = automatic HTTPS). Use the bare VPS IP for a quick HTTP test.
SITE_DOMAIN=crm.emselriyadh.com
# Full origin used for the backend CORS allow-list
SITE_URL=https://crm.emselriyadh.com

# Secrets — generate strong random values
POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me-long-random-string
PUBLIC_API_KEY=change-me-random

# Tap payment gateway (https://dashboard.tap.company) — secret key sk_test_... / sk_live_...
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
PUBLIC_BASE_URL=https://crm.emselriyadh.com
